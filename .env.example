# ══════════════════════════════════════════
# Metalworking Center LLC — Environment Template
# Copy to .env and fill in values
# ══════════════════════════════════════════

# Server
NODE_ENV=production
PORT=3000
HOST=0.0.0.0

# JWT Authentication (generate: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))")
JWT_SECRET=CHANGE_ME_GENERATE_RANDOM_SECRET

# Database & Storage
# Render: use persistent disk mount path (e.g. /data)
DB_PATH=./data.json
BACKUP_DIR=./backups
UPLOAD_DIR=./public/uploads

# Bank statement folders (optional — auto-import feature)
BANK_STATEMENT_KASS=
BANK_STATEMENT_TDB=
