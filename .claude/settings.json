{
  "permissions": {
    "allow": [
      "Bash(npm start)",
      "Bash(node server.js)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git switch *)",
      "Bash(git checkout -b *)",
      "Bash(git push -u origin feat/*)",
      "Bash(git push origin feat/*)",
      "Bash(git push -u origin fix/*)",
      "Bash(git push origin fix/*)"
    ],
    "deny": [
      "Bash(git push --force*)",
      "Bash(git push --force-with-lease*)",
      "Bash(git push -f *)",
      "Read(.env)",
      "Edit(.env)",
      "Write(.env)"
    ]
  }
}
